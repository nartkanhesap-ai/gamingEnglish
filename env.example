{
  "name": "gaming-english-word-updater",
  "version": "1.0.0",
  "description": "Monthly word update script for Gaming English",
  "main": "update-words.js",
  "scripts": {
    "update": "node update-words.js",
    "update:dry": "node update-words.js --dry-run",
    "update:month": "node update-words.js --month="
  },
  "dependencies": {
    "@anthropic/sdk": "^0.24.0",
    "firebase-admin": "^12.0.0",
    "dotenv": "^16.0.0"
  }
}
